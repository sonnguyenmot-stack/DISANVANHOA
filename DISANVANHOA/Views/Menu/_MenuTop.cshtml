@model IEnumerable<DISANVANHOA.Models.EF.Category>
@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        if (item.Alias.Equals("trang-chu"))
        {
            item.Alias = "";
        }
        if (!string.IsNullOrEmpty(item.link))
        {
            item.Alias = item.link;
        }
        <li class=""><a href="/@item.Alias">@item.Title</a></li>
    }
}
<link href="~/Content/assets/styles/banner.css" rel="stylesheet" />
