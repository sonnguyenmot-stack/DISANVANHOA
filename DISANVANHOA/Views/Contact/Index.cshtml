@section scripts{
    <script src="~/Content/assets/js/contact_custom.js"></script>

    <script>
        function searchMap() {
            var location = document.getElementById("searchLocation").value;
            if (location.trim() === "") {
                alert("Vui lòng nhập địa điểm!");
                return;
            }

            var mapFrame = document.getElementById("mapIframe");

            // Encode để tránh lỗi URL
            var encoded = encodeURIComponent(location);
            // Thay đổi bản đồ
            mapFrame.src = "https://www.google.com/maps?q=" + encoded + "&output=embed";
        }
    </script>
}
