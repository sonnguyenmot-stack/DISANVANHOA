@model IEnumerable<DISANVANHOA.Models.EF.Contact>
<link rel="stylesheet" type="text/css" href="~/Content/assets/styles/contact_styles.css">


<link href="~/Content/assets/styles/bando.css" rel="stylesheet" />
<div class="container contact_container">
    <div class="row">
        <div class="col">

            <!-- Breadcrumbs -->

            <div class="breadcrumbs d-flex flex-row align-items-center">
                <ul>
                    <li><a href="/">Trang chủ</a></li>
                    <li class="active"><a href="#"><i class="fa fa-angle-right" aria-hidden="true"></i>Bản Đồ</a></li>
                </ul>
            </div>

        </div>
    </div>

    <!-- Map Container -->
    @*<div class="contact_container">*@

    <!-- Thanh tìm kiếm -->
    <div class="search_bar_wrapper">
        <input type="text" id="searchLocation" placeholder="Nhập địa điểm cần tìm..." />
        <button class="btn-search-custom" onclick="searchMap()">Tìm</button>
    </div>

    <!-- Bản đồ -->
    <div class="map_container">
        <iframe id="mapIframe"
                src="https://www.google.com/maps?q=Trường+THPT+Phú+Lương&output=embed"
                allowfullscreen
                loading="lazy">
        </iframe>
    </div>

    @*</div>*@


    <!-- Contact Us -->


</div>

