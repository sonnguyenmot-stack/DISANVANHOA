<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🌾AI di sản văn hóa | Đăng Nhập</title>
    <!-- 🌾 FAVICON CHỈ DÙNG BÔNG LÚA -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png">
    <link rel="stylesheet" href="~/Content/login/style.css">
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <div class="neu-icon">
                    <div class="icon-inner">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                    </div>
                </div>
                <h2>Chào Mừng</h2>
                <p>Đến với AI di sản văn hóa Tuyên Quang</p>
            </div>

            @RenderBody()
        </div>
    </div>

    <script src="~/Content/login/shared/js/form-utils.js"></script>
    <script src="~/Content/login/script.js"></script>
    <script src="~/Content/login/script.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>