<!-- Content Header (Page header) -->
<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Thêm mới câu hỏi</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="#">Danh mục</a></li>
                    <li class="breadcrumb-item active">Thêm mới</li>
                </ol>
            </div>
        </div>
    </div><!-- /.container-fluid -->
</section>

<!-- Main content -->
<section class="content">

    <!-- Default box -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Thông tin thêm mới câu hỏi</h3>
        </div>
        <div class="card-body">
            <div class="bs-stepper-content">
                @using (Html.BeginForm("Add", "QuestionDiSan", FormMethod.Post, new { }))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true)
                    <!-- your steps content here -->
                <div id="logins-part" class="content active dstepper-block" role="tabpanel" aria-labelledby="logins-part-trigger">
                    <div class="form-group">
                        <label for="exampleInputEmail1">Tên danh mục</label>
                        @Html.TextBoxFor(x => x.Name, new { @class = "form-control", @placeholder = "câu hỏi" })
                        @Html.ValidationMessageFor(x => x.Name, null, new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        <label>Ảnh 1</label>
                        <div class="input-group">
                            @Html.TextBoxFor(x => x.Img1, new { @id = "img1", @class = "form-control" })
                            <div class="input-group-append">
                                <input type="button" value="Tải ảnh" onclick="BrowseServer('img1');" />
                            </div>
                        </div>
                    </div>

                    @*<div class="form-group">
                        <label>Ảnh 2</label>
                        <div class="input-group">
                            @Html.TextBoxFor(x => x.Img2, new { @id = "img2", @class = "form-control" })
                            <div class="input-group-append">
                                <input type="button" value="Tải ảnh" onclick="BrowseServer('img2');" />
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Ảnh 3</label>
                        <div class="input-group">
                            @Html.TextBoxFor(x => x.Img3, new { @id = "img3", @class = "form-control" })
                            <div class="input-group-append">
                                <input type="button" value="Tải ảnh" onclick="BrowseServer('img3');" />
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Ảnh 4</label>
                        <div class="input-group">
                            @Html.TextBoxFor(x => x.Img4, new { @id = "img4", @class = "form-control" })
                            <div class="input-group-append">
                                <input type="button" value="Tải ảnh" onclick="BrowseServer('img4');" />
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Đáp án đúng</label>
                        <div class="input-group">
                            @Html.DropDownListFor(x => x.result,
                                new List<SelectListItem>
                                {
                                    new SelectListItem { Text="A", Value="1" },
                                    new SelectListItem { Text="B", Value="2" },
                                    new SelectListItem { Text="C", Value="3" },
                                    new SelectListItem { Text="D", Value="4" }
                                }, "-- Chọn đáp án đúng --",
                                new { @class = "form-control" })
                        </div>
                        @Html.ValidationMessageFor(x => x.result, null, new { @class = "text-danger" })
                    </div>*@


