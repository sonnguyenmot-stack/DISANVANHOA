@model IEnumerable<DISANVANHOA.Models.EF.General>
@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {

        <div class="owl-item product_slider_item">
            <div class="product-item @item.Alias">
                <div class="product discount">
                    <div class="product_image">
                        <img src="@item.Icon" alt="@item.Title" width="221" height="221">
                    </div>
                    <div class="favorite favorite_left"></div>
                    @*<div class="product_bubble product_bubble_right product_bubble_red d-flex flex-column align-items-center"><span>-$20</span></div>*@
                    <div class="product_info">
                        <h6 class="product_name"><a href="chi-tiet-giao-trinh/@item.Alias-k@(item.Id)">@item.Title</a></h6>
                        @*<div class="product_price">$520.00<span>$590.00</span></div>*@
                    </div>
                </div>
            </div>
        </div>


    }
}

<style>
    /* --- Container OWL item --- */
    .product_slider_item {
        padding: 12px;
        box-sizing: border-box;
    }

    /* --- Card sản phẩm phong cách TMĐT --- */
    .product-item {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        position: relative;
        border: 1px solid #eee;
        transition: .25s ease;
    }

        .product-item:hover {
            border-color: #ff5722; /* Màu cam Shopee */
            box-shadow: 0 6px 16px rgba(0,0,0,0.12);
            transform: translateY(-4px);
        }

    /* --- Khu vực hình sản phẩm --- */
    .product_image {
        width: 100%;
        height: 230px;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        .product_image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: .35s ease;
        }

    .product-item:hover .product_image img {
        transform: scale(1.07);
    }

    /* --- Tên sản phẩm liền khối --- */
    .product_info {
        padding: 12px;
        background: #fff;
    }

    .product_name {
        font-size: 15px;
        font-weight: 600;
        line-height: 1.3;
        height: 38px; /* 2 dòng */
        overflow: hidden;
        margin-bottom: 6px;
    }

        .product_name a {
            color: #333;
            text-decoration: none;
        }

            .product_name a:hover {
                color: #ff5722;
            }

    /* --- Icon yêu thích (tùy chọn) --- */
    .favorite {
        width: 35px;
        height: 35px;
        background: url('/Content/icons/heart.png') no-repeat center;
        background-size: 23px;
        position: absolute;
        top: 10px;
        right: 10px;
        opacity: .85;
        transition: .25s;
    }

        .favorite:hover {
            transform: scale(1.15);
            opacity: 1;
        }
      
   

</style>



