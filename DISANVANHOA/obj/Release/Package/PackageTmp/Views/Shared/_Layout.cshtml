    <script>
        const loader = document.getElementById('ftco-loader');

        // Hiển thị loader
        function showLoader() {
            if (loader) loader.classList.remove('hide');
        }

        // Ẩn loader
        function hideLoader() {
            if (loader) loader.classList.add('hide');
        }

        // Khi trang load xong
        window.addEventListener('load', hideLoader);

        // Khi back/forward từ cache
        window.addEventListener('pageshow', function (event) {
            if (event.persisted) { // trang được phục hồi từ cache
                showLoader();
                setTimeout(hideLoader, 500); // delay ngắn để hiển thị loader
            } else {
                hideLoader();
            }
        });

        // Ẩn loader tự động sau 5 giây phòng trường hợp load lâu
        setTimeout(hideLoader, 5000);

        // Hiển thị loader khi click link nội bộ (class="show-loader")
        document.querySelectorAll('a.show-loader').forEach(link => {
            link.addEventListener('click', function (e) {
                const href = this.getAttribute('href');
                if (!href || href.startsWith('#') || href.startsWith('javascript:')) return;
                e.preventDefault();
                showLoader();
                setTimeout(() => {
                    window.location.href = href;
                }, 100);
            });
        });

    </script>
