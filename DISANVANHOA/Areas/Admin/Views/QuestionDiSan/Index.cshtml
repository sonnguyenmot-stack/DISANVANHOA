@model IEnumerable<DISANVANHOA.Models.EF.QuestionDiSan>
@{
    ViewBag.Title = "Hình ảnh";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@section naviheader{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="/admin/home" class="nav-link">Trang chủ</a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="/admin/QuestionDiSan" class="nav-link">@ViewBag.Title</a>
        </li>
    </ul>
}

<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6"><h1>Quản Lý Câu hỏi hình ảnh</h1></div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/admin/home">Trang Chủ</a></li>
                    <li class="breadcrumb-item active">@ViewBag.Title</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<section class="content">
    <div class="card">
        <div class="card-header d-flex justify-content-between flex-wrap">
            <h3 class="card-title">Danh sách câu hỏi hình ảnh</h3>
            <div class="card-tools">
                <a href="/admin/QuestionDiSan/add" class="btn btn-outline-success btn-sm">Thêm mới</a>
            </div>
        </div>

        <div class="card-body">
            <!-- Desktop Table -->
            <div class="table-responsive d-none d-sm-block">
                <table class="table table-hover table-bordered mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th>STT</th>
                            <th>Câu hỏi</th>
                            <th>Hình ảnh</th>
                            <th>Chức năng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            var i = 1;
                            foreach (var item in Model)
                            {
                                <tr id="trow_@item.Id">
                                    <td>@i</td>
                                    <td>@item.Name</td>
                                    <td><img src="@item.Img1" width="50" /></td>
                                    <td>
                                        <a href="/admin/QuestionDiSan/edit/@item.Id" class="btn btn-sm btn-outline-warning mb-1">Sửa</a>
                                        <a href="#" data-id="@item.Id" class="btn btn-sm btn-outline-danger btnDelete mb-1">Xóa</a>
                                    </td>
                                </tr>
                                i++;
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="text-center">Không có bản ghi nào!</td></tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Mobile Card List -->
            <div class="d-block d-sm-none">
                @if (Model != null && Model.Any())
                {
                    var i = 1;
                    foreach (var item in Model)
                    {
                        <div class="card mb-2 p-2 border">
                            <div class="d-flex justify-content-between flex-wrap">
                                <div>
                                    <strong>@i. @item.Name</strong><br />
                                    <img src="@item.Img1" width="100" class="mb-1" />
                                </div>
                                <div class="mt-1">
                                    <a href="/admin/QuestionDiSan/edit/@item.Id" class="btn btn-sm btn-outline-warning mb-1">Sửa</a>
                                    <a href="#" data-id="@item.Id" class="btn btn-sm btn-outline-danger btnDelete">Xóa</a>
                                </div>
                            </div>
                        </div>
                        i++;
                    }
                }
            </div>
        </div>
    </div>
</section>

@section scripts{
    <script>
        $(document).ready(function () {
            $('body').on('click', '.btnDelete', function () {
                var id = $(this).data("id");
                if (confirm('Bạn có muốn xóa bản ghi này không?')) {
                    $.post('/admin/QuestionDiSan/delete', { id: id }, function (rs) {
                        if (rs.success) $('#trow_' + id).remove();
                    });
                }
            });
        });
    </script>
}
